<?xml version="1.0"?>
<!-- GENERATED by robot_assets from Onshape CAD. Do not edit by hand. Regenerate: robot-assets-generate lite_biped -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="lite_biped">
  <xacro:arg name="use_fake_hardware" default="true"/>
  <xacro:arg name="use_sim" default="false"/>
  <xacro:arg name="mode" default="legs"/>
  <xacro:arg name="can_interface_left" default="can2"/>
  <xacro:arg name="can_interface_right" default="can3"/>
  <xacro:arg name="calibration_file" default=""/>
  <xacro:arg name="imu_port" default="/dev/ttyUSB0"/>

  <xacro:include filename="$(find lite_description)/robots/lite_biped/xacro/lite_biped.description.xacro"/>
  <xacro:include filename="$(find lite_description)/robots/lite_biped/xacro/lite_biped.ros2_control.xacro"/>

  <xacro:lite_biped_description/>

  <xacro:lite_biped_ros2_control
    name="LiteBipedHardware"
    use_fake_hardware="$(arg use_fake_hardware)"
    use_sim="$(arg use_sim)"
    mode="$(arg mode)"
    can_interface_left="$(arg can_interface_left)"
    can_interface_right="$(arg can_interface_right)"
    calibration_file="$(arg calibration_file)"
    imu_port="$(arg imu_port)"/>
</robot>
