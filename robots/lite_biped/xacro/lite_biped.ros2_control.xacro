                      use_fake_hardware="${use_fake_hardware}" use_sim="${use_sim}"/>
  </xacro:macro>

  <!-- Combined single-block layout for the sim and mock backends. -->
  <xacro:macro name="lite_biped_ros2_control_combined" params="name use_fake_hardware use_sim">
    <ros2_control name="${name}" type="system">
      <hardware>
        <xacro:if value="${use_sim}">
          <plugin>mujoco_ros2_control/MujocoSystem</plugin>
        </xacro:if>
        <xacro:unless value="${use_sim}">
          <plugin>mock_components/GenericSystem</plugin>
        </xacro:unless>
      </hardware>
      <xacro:lite_biped_left_leg_joints use_fake_hardware="${use_fake_hardware}" use_sim="${use_sim}"/>
      <xacro:lite_biped_right_leg_joints use_fake_hardware="${use_fake_hardware}" use_sim="${use_sim}"/>
      <xacro:if value="${use_sim}">
        <sensor name="base_imu">
          <state_interface name="orientation.x"/>
          <state_interface name="orientation.y"/>
          <state_interface name="orientation.z"/>
          <state_interface name="orientation.w"/>
          <state_interface name="angular_velocity.x"/>
          <state_interface name="angular_velocity.y"/>
          <state_interface name="angular_velocity.z"/>
          <state_interface name="linear_acceleration.x"/>
          <state_interface name="linear_acceleration.y"/>
          <state_interface name="linear_acceleration.z"/>
        </sensor>
      </xacro:if>
    </ros2_control>
  </xacro:macro>

  <!-- Real hardware: one <ros2_control> block per CAN bus. The controller_manager
       runs them concurrently and exposes a single flat joint list to controllers. -->
  <xacro:macro name="lite_biped_ros2_control_real"
               params="mode can_interface_left can_interface_right calibration_file">
    <ros2_control name="LiteBipedLeftLeg" type="system">
      <hardware>
        <plugin>humanoid_devices_robstride/RobstrideSystem</plugin>
        <param name="can_interface">${can_interface_left}</param>
        <param name="calibration_file">${calibration_file}</param>
      </hardware>
      <xacro:lite_biped_left_leg_joints use_fake_hardware="false" use_sim="false"/>
    </ros2_control>
    <ros2_control name="LiteBipedRightLeg" type="system">
      <hardware>
        <plugin>humanoid_devices_robstride/RobstrideSystem</plugin>
        <param name="can_interface">${can_interface_right}</param>
        <param name="calibration_file">${calibration_file}</param>
      </hardware>
      <xacro:lite_biped_right_leg_joints use_fake_hardware="false" use_sim="false"/>
    </ros2_control>
  </xacro:macro>

  <!-- Top-level dispatch: combined block for sim/mock, per-bus blocks for real
       (use_sim wins over use_fake_hardware, matching franka_ros2 / UR precedence). -->
  <xacro:macro name="lite_biped_ros2_control"
               params="name use_fake_hardware use_sim mode
                       can_interface_left can_interface_right calibration_file">
    <xacro:if value="${use_sim or use_fake_hardware}">
      <xacro:lite_biped_ros2_control_combined name="${name}"
        use_fake_hardware="${use_fake_hardware}" use_sim="${use_sim}"/>
    </xacro:if>
    <xacro:unless value="${use_sim or use_fake_hardware}">
      <xacro:lite_biped_ros2_control_real mode="${mode}"
        can_interface_left="${can_interface_left}"
        can_interface_right="${can_interface_right}"
        calibration_file="${calibration_file}"/>
    </xacro:unless>
  </xacro:macro>

</robot>
