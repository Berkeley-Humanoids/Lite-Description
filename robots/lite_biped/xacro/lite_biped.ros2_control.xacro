                      use_fake_hardware="${use_fake_hardware}" use_sim="${use_sim}"/>
    <xacro:lite_biped_joint name="left_ankle_pitch" can_id="36" model="rs-00" direction="1"
                      lower_limit="-0.523599" upper_limit="0.872665"
                      torque_limit="14.0" current_limit="16"
                      use_fake_hardware="${use_fake_hardware}" use_sim="${use_sim}"/>
    <xacro:lite_biped_joint name="left_ankle_roll" can_id="37" model="rs-05" direction="-1"
                      lower_limit="-0.349066" upper_limit="0.349066"
                      torque_limit="5.5" current_limit="14"
                      use_fake_hardware="${use_fake_hardware}" use_sim="${use_sim}"/>
  </xacro:macro>

  <xacro:macro name="lite_biped_right_leg_joints" params="use_fake_hardware use_sim">
    <xacro:lite_biped_joint name="right_hip_pitch" can_id="41" model="rs-06" direction="1"
                      lower_limit="-2.35619" upper_limit="0.785398"
