    <xacro:lite_biped_joint name="left_hip_yaw" can_id="33" model="rs-02" direction="1"
                      lower_limit="-1.5708" upper_limit="1.5708"
                      torque_limit="17.0" current_limit="27"
                      use_fake_hardware="${use_fake_hardware}" use_sim="${use_sim}"/>
    <xacro:lite_biped_joint name="left_knee_pitch" can_id="34" model="rs-06" direction="-1"
                      lower_limit="0.0" upper_limit="2.35619"
                      torque_limit="36.0" current_limit="43"
                      use_fake_hardware="${use_fake_hardware}" use_sim="${use_sim}"/>
    <xacro:lite_biped_joint name="left_ankle_yaw" can_id="35" model="rs-00" direction="1"
